    function startUpdateBill(index, total) {
		var item = '.tr_'+ index;
		
		if(index < total) {
		    if($(item + ' .product').text() != '' && $(item + ' .company_branch').text() == '') {
                $.ajax({
        			url: "<?php echo $this->url('routeAdmin/default', array('controller' => $this->params['controller'], 'action' => 'update'));?>",
        			type: 'POST',
        			data: {
        				'id': $(item).attr('data-id'),
                        'code': $(item + ' .code').text(),
        			},
        			beforeSend: function() {
        				$(item + ' .company_branch').html('<span class="btn btn-xs yellow">Load</span>');
        			},
        			success: function(result) {
        				setTimeout(function(){
        					if(result != '') {
        					    $(item + ' .company_branch').html('<span class="btn btn-xs green">'+ result +'</span>');
        					} else {
        						$(item + ' .company_branch').html('<span class="btn btn-xs red">Không tìm thấy</span>');
        					}
        				    index = index + 1;
        				    startUpdateBill(index, total); 
        			    }, 100);
        			}
        		});
    		} else {
    		    if($(item + ' .company_branch').text() == '') {
        		    $(item + ' .company_branch').html('<span class="btn btn-xs red">Loại</span>');
        		    index = index + 1;
    			    startUpdateBill(index, total); 
			    } else {
			        index = index + 1;
    			    startUpdateBill(index, total); 
			    }
    		}
		} else {
		    alert('Đã import thành công');
		}
	}
	
